{
  "name": "@nodaste-lab/weft",
  "version": "0.1.1",
  "type": "module",
  "license": "UNLICENSED",
  "description": "Weft design system: --weft-* tokens, framework-agnostic weft-* component classes, and the shadcn-based React primitive library shared across Nodaste products.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist",
    "src",
    "css",
    "tooling",
    "manifest.json",
    "props-snapshot.json",
    "docs"
  ],
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./tokens.css": "./css/weft.css",
    "./theme.css": "./css/theme.css",
    "./components.css": "./css/weft-components.css",
    "./fonts.css": "./css/fonts.css",
    "./tailwind.css": "./css/tailwind.css",
    "./index.css": "./css/index.css",
    "./tooling/raw-colors": "./tooling/raw-color-pattern.js",
    "./manifest.json": "./manifest.json",
    "./props-snapshot.json": "./props-snapshot.json",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "verify": "node scripts/verify-design-system-manifest.mjs",
    "props": "node scripts/design-system-props.mjs",
    "props:write": "node scripts/design-system-props.mjs --write",
    "test:props": "node --test scripts/__tests__/design-system-props.node.mjs",
    "test": "vitest run",
    "changeset": "changeset",
    "site:dev": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts",
    "test:visual": "npm run site:build && playwright test",
    "test:visual:update": "npm run site:build && playwright test --update-snapshots"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19",
    "react-dom": "^18.3.1 || ^19",
    "tailwindcss": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/inter-tight": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "3.6.0",
    "lucide-react": "0.487.0",
    "next-themes": "0.4.6",
    "react-day-picker": "8.10.1",
    "react-hook-form": "7.55.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "2.1.7",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "@babel/parser": "^7.29.3",
    "@changesets/cli": "^2.29.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@vitejs/plugin-react": "4.7.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vitest": "^4.0.18",
    "vite": "6.4.2",
    "@playwright/test": "^1.61.1",
    "tailwindcss": "4.1.12",
    "@tailwindcss/vite": "4.1.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nodaste-Lab/weft.git"
  }
}
